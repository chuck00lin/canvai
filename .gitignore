# dependencies / builds
node_modules/
dist/
build/
coverage/
.turbo/
.cache/

# env & local config
.env
.env.*
*.local

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# safety net: internal material never ships.
# The real data/boards live OUTSIDE this repo (../pairsketch-internal/), and
# the hub runs with --root pointing there. These patterns catch anything
# dropped here by habit.
internal/
notes/
scratch/
*.internal.*

# private user data — boards and uploaded images live in ../pairsketch-internal/
discuss/
assets/

# pairsketch hub local state
.pairsketch/
